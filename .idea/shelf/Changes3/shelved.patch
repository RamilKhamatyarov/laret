+package com.rkhamatyarov.laret.completion.template
+
+class TemplateEngine {
+    private val variableRegex = Regex("""\{\{\s*([\w.]+)\s*\}\}""")
+    private val loopRegex = Regex("""\{\{#each\s+([\w.]+)\s*\}\}(.*?)\{\{/each\}\}""", RegexOption.DOT_MATCHES_ALL)
+
+    fun render(template: String, context: Map<String, Any?>): String {
+        var result = template
+
+        // Process loops first (may be nested, so loop until no more matches)
+        var hasChanges = true
+        var iterations = 0
+        while (hasChanges && iterations < 100) {
+            iterations++
+            val match = loopRegex.find(result)
+            if (match != null) {
+                val collectionName = match.groupValues[1]
+                val loopBody = match.groupValues[2]
+                val collection = resolvePath(context, collectionName) as? Collection<*> ?: emptyList<Any>()
+
+                // CRITICAL FIX: Convert each item to Map for nested template access
+                val rendered = collection.joinToString("") { item ->
+                    val itemMap = convertToMap(item)
+                    val itemContext = context.toMutableMap().apply {
+                        this["item"] = itemMap
+                    }
+                    render(loopBody, itemContext)
+                }
+
+                result = result.replaceFirst(match.value, rendered)
+            } else {
+                hasChanges = false
+            }
+        }
+
+        // Then process variables
+        hasChanges = true
+        iterations = 0
+        while (hasChanges && iterations < 100) {
+            iterations++
+            val match = variableRegex.find(result)
+            if (match != null) {
+                val varName = match.groupValues[1]
+                val value = resolvePath(context, varName)?.toString() ?: ""
+                result = result.replaceFirst(match.value, value)
+            } else {
+                hasChanges = false
+            }
+        }
+
+        return result
+    }
+
+    // CRITICAL: Convert loop items to Map for nested property access
+    private fun convertToMap(item: Any?): Map<String, Any?> {
+        return when (item) {
+            is TemplateContext.GroupContext -> item.toMap()
+            is TemplateContext.CommandContext -> item.toMap()
+            is TemplateContext.OptionContext -> item.toMap()
+            is Map<*, *> -> item as Map<String, Any?>
+            else -> mapOf("value" to item)
+        }
+    }
+
+    private fun resolvePath(context: Map<String, Any?>, path: String): Any? {
+        // Handle item.property access (for loop contexts)
+        if (path.startsWith("item.")) {
+            val item = context["item"] ?: return null
+            val property = path.substringAfter("item.")
+            return when (item) {
+                is Map<*, *> -> item[property]
+                is TemplateContext.GroupContext -> when (property) {
+                    "name" -> item.name
+                    "commands" -> item.commands
+                    else -> null
+                }
+                is TemplateContext.CommandContext -> when (property) {
+                    "name" -> item.name
+                    "description" -> item.description
+                    "options" -> item.options
+                    else -> null
+                }
+                is TemplateContext.OptionContext -> when (property) {
+                    "long" -> item.long
+                    "short" -> item.short
+                    "description" -> item.description
+                    else -> null
+                }
+                else -> null
+            }
+        }
+
+        // Direct property access
+        return context[path]
+    }
+
+    fun render(template: String, context: TemplateContext): String {
+        return render(template, context.toMap())
+    }
+}
