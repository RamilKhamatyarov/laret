+#compdef {{appName}}
+# Zsh completion for {{appName}}
+# Generated by Laret CLI framework
+
+_{{appName}}() {
+    local -a commands
+    # Generate list of commands with descriptions
+    commands=(\n{{#each groups}}\n        \'{{item.name}}:{{item.name}} command\'\n{{/each}}\n    )
+
+    local -a options
+    # Generate list of options with descriptions
+    options=(\n        \'--help[Show help]\' \'-h[Show help]\'\n        \'--version[Show version]\' \'-v[Show version]\'\n{{#each groups}}\n{{#each item.commands}}\n{{#each item.options}}\n        \'--{{item.long}}[{{item.description}}]\' \'-{{item.short}}[{{item.description}}]\'\n{{/each}}\n{{/each}}\n{{/each}}\n    )
+
+    # Use _describe for commands and _arguments for options
+    _describe 'commands' commands
+    _arguments "${options[@]}"
+}
