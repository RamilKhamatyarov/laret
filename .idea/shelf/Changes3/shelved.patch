-                "'(--help -h)'{--help,-h}'[Show help message]'",
-                "'(--version -v)'{--version,-v}'[Show version]'",
-            )
-
-        val allOptions =
-            (commandOptions + globalOptions)
-                .distinct()
-                .joinToString(" \\\n                ")
-
-        return """
-            #compdef $appName
-            
-            _$appName() {
