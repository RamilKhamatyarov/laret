+# PowerShell completion for {{appName}}
+# Generated by Laret CLI framework
+
+$scriptblock = {\n    param($wordToComplete, $commandAst, $cursorPosition)\n    \n    $command = $commandAst.ToString()\n    # Split command into tokens
+    $tokens = @($command -split '\\s+' | Where-Object { $_.Trim() })\n    \n    # Find the index of the application name\n    $appIndex = -1\n    for ($i = 0; $i -lt $tokens.Count; $i++) {\n        if ($tokens[$i] -eq '{{appName}}' -or $tokens[$i] -eq '{{appName}}.exe') {\n            $appIndex = $i\n            break\n        }\n    }\n    \n    if ($appIndex -eq -1) { return }\n    \n    # Extract arguments after the app name\n    $allArgs = @($tokens[($appIndex + 1)..($tokens.Count - 1)])\n    $positionalArgs = @($allArgs | Where-Object { !$_.StartsWith('-') })\n    $argCount = $positionalArgs.Count\n    \n    $completions = @()\n    \n    if ($argCount -eq 0) {\n        # Top-level completion: show groups\n        $completions = @(\n{{#each groups}}\n            '{{item.name}}'\n{{/each}}\n        )\n    }\n    elseif ($argCount -eq 1) {\n        # Second-level completion: show commands within a group\n        $group = $positionalArgs[0]\n        switch ($group) {\n{{#each groups}}\n            '{{item.name}}' {\n                $completions = @(\n{{#each item.commands}}\n                        '{{item.name}}'\n{{/each}}\n                )\n            }\n{{/each}}\n            default {\n                # Fallback: show all groups if group is unknown\n                $completions = @(\n{{#each groups}}\n                    '{{item.name}}'\n{{/each}}\n                ) | Where-Object { $_ -like "$group*" }\n            }\n        }\n    }\n    else {\n        # Third+ level completion: show options\n        $completions = @(\n            '--help', '-h', '--version', '-v'\n{{#each groups}}\n{{#each item.commands}}\n{{#each item.options}}\n            '--{{item.long}}', '-{{item.short}}'\n{{/each}}\n{{/each}}\n{{/each}}\n        )\n    }\n    \n    # Filter, format, and return results\n    $completions |\n        Where-Object { $_ -like "$wordToComplete*" } |\n        ForEach-Object {\n            [System.Management.Automation.CompletionResult]::new($_, $_, 'ParameterValue', $_)\n        }\n}\n\n# Register the completer for both the app name and app.exe\nRegister-ArgumentCompleter -CommandName {{appName}} -ScriptBlock $scriptblock\nRegister-ArgumentCompleter -CommandName {{appName}}.exe -ScriptBlock $scriptblock
