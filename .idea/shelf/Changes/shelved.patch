<+>package com.rkhamatyarov.laret.config\n\nimport java.io.File\n\nenum class ConfigFormat {\n    YAML,\n    TOML,\n    JSON,\n    ;\n\n    companion object {\n        fun fromFile(file: File): ConfigFormat? = when (file.extension.lowercase()) {\n            \"yml\",\n            \"yaml\",\n            -> YAML\n            \"toml\" -> TOML\n            \"json\" -> JSON\n            else -> null\n        }\n\n        fun fromFileName(fileName: String): ConfigFormat? = when {\n            fileName.endsWith(\".yml\") || fileName.endsWith(\".yaml\") -> YAML\n            fileName.endsWith(\".toml\") -> TOML\n            fileName.endsWith(\".json\") -> JSON\n            else -> null\n        }\n    }\n}\n
